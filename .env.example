# Copy to .env and adjust. All values are optional — the setup wizard can fill
# everything in the web UI instead. Secrets are NOT required here.

# Web port (host:container is set in docker-compose). Default 9878.
PORT=9878

# Match these to your media files' owner so written .cs.srt files are readable.
PUID=1000
PGID=1000

TZ=Europe/Prague

# --- Optional: provide secrets via env instead of the wizard ---
# Any of these may also be supplied as *_FILE pointing at a Docker secret file,
# e.g. GEMINI_API_KEY_FILE=/run/secrets/gemini_key
# GEMINI_API_KEY=
# SONARR_URL=http://sonarr:8989
# SONARR_API_KEY=
# RADARR_URL=http://radarr:7878
# RADARR_API_KEY=
