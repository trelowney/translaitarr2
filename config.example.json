{
  "_comment": "Copy nothing manually — this file documents the shape of config/config.json, which the first-run setup wizard creates for you. Secrets stay in config/ and are never committed.",

  "onboarding_completed": false,

  "auth": {
    "enabled": false,
    "password_hash": ""
  },

  "arr": {
    "sonarr": { "url": "http://sonarr:8989", "api_key": "" },
    "radarr": { "url": "http://radarr:7878", "api_key": "" }
  },

  "gemini": {
    "api_key": "",
    "models": [
      "gemini-3.1-flash-lite",
      "gemini-3.5-flash",
      "gemini-3-flash-preview",
      "gemini-2.5-flash",
      "gemini-flash-latest",
      "gemini-2.5-flash-lite",
      "gemini-flash-lite-latest",
      "gemini-2.0-flash",
      "gemini-2.0-flash-lite"
    ],
    "model_batch": {
      "gemini-3.5-flash": 200,
      "gemini-3-flash-preview": 200,
      "gemini-2.5-flash": 200,
      "gemini-flash-latest": 200,
      "gemini-2.0-flash": 200
    },
    "model_daily_limit": {}
  },

  "_providers_comment": "AI provider priority: primary first, then secondary, then tertiary ('none' to skip). Each provider below is configured in Settings → AI providers. LLM providers take an api_key + a models list (with optional per-model batch/daily-limit); MT engines need only a key or URL.",
  "ai": { "primary": "gemini", "secondary": "none", "tertiary": "none" },

  "openrouter": { "api_key": "", "models": [], "model_batch": {}, "model_daily_limit": {} },
  "openai_compat": { "api_key": "", "base_url": "", "models": [], "model_batch": {}, "model_daily_limit": {} },
  "anthropic": { "api_key": "", "base_url": "", "models": [], "model_batch": {}, "model_daily_limit": {} },
  "cloudflare": { "api_key": "", "account_id": "", "models": [], "model_batch": {}, "model_daily_limit": {} },
  "deepl": { "api_key": "" },
  "libretranslate": { "api_key": "", "base_url": "" },
  "google": { "api_key": "" },
  "azure": { "api_key": "", "region": "" },
  "yandex": { "api_key": "", "folder_id": "" },

  "languages": {
    "source_priority": ["eng", "fra", "deu", "spa"],
    "target": { "name": "Czech", "code": "cs" }
  },

  "paths": {
    "remap": []
  },

  "sdh": {
    "brackets": true,
    "parens": true,
    "music": true,
    "speaker": true,
    "uppercase": false
  },

  "limits": {
    "max_daily_per_model": 18,
    "max_daily_total": 120,
    "max_per_run": 10
  },

  "automation": {
    "enabled": false,
    "scan_interval_minutes": 30,
    "rpd_reset_tz": "America/Los_Angeles"
  },

  "_telemetry_comment": "Anonymous active-instance counter — opt-out (on by default). Sends only a random instance_id + the app version once a day; nothing else. Set enabled=false (or env TELEMETRY=off) to disable. See the README's Privacy section.",
  "telemetry": {
    "enabled": true,
    "instance_id": ""
  },

  "translation": {
    "api_timeout": 1200,
    "max_output_tokens": 65536,
    "max_retries": 3,
    "retry_delay": 5,
    "context_enabled": true,
    "context_before": 2,
    "context_after": 2,
    "add_translator_credit": false,
    "batch_size": 150,
    "source_preference": "video",
    "verify": false,
    "verify_samples": 8
  },

  "validation": {
    "enabled": true,
    "min_chars": 1,
    "max_chars": 200,
    "min_duration_ms": 100,
    "max_duration_s": 15
  }
}
